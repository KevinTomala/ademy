# Resend API key — obtener en resend.com/api-keys
RESEND_API_KEY=

# Email desde donde se envía (debe estar verificado en Resend)
# En modo prueba puedes usar: onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev

# Email donde llegan las solicitudes de demo
DEMO_TO_EMAIL=@gmail.com

# reCAPTCHA v2 — obtener en https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_TYPE=v2
CONTACT_RECAPTCHA_ENABLED=true
CONTACT_RECAPTCHA_PROVIDER=classic
CONTACT_RECAPTCHA_SECRET=
VITE_RECAPTCHA_SITE_KEY=